{
  "name": "@tenonhq/sincronia-core",
  "version": "0.0.59",
  "description": "Next-gen file syncer",
  "license": "GPL-3.0",
  "main": "./dist/index.js",
  "author": "Multiple",
  "private": false,
  "scripts": {
    "copy:skills": "mkdir -p skills && cp ../../skills/*.md ./skills/",
    "prepack": "npm run copy:skills && tsc",
    "test": "jest --ci --reporters=jest-junit --reporters=default --coverage --coverageReporters=cobertura --coverageReporters=html",
    "version:bump": "node ./../../Scripts/bump-version.js ./package.json",
    "postpublish": "npm run version:bump"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tenon/sincronia.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@tenonhq/sincronia-types": "^0.0.6",
    "@types/dotenv": "^6.1.1",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.5",
    "@types/lodash": "^4.14.199",
    "@types/node": "^20.8.4",
    "@types/tough-cookie": "^4.0.5",
    "@types/prettier": "^2.7.3",
    "@types/progress": "^2.0.5",
    "@types/yargs": "^17.0.28",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "@tenonhq/sincronia-schema": "^0.0.1",
    "axios": "^1.5.1",
    "axios-cookiejar-support": "^4.0.7",
    "axios-rate-limit": "^1.3.0",
    "chalk": "^4.1.2",
    "chokidar": "^3.5.3",
    "dotenv": "^16.3.1",
    "inquirer": "^8.2.6",
    "lodash": "^4.17.21",
    "prettier": "3.0.3",
    "tough-cookie": "^4.1.3",
    "progress": "^2.0.3",
    "winston": "^3.11.0",
    "yargs": "^17.7.2"
  },
  "bin": {
    "sinc": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "skills/**/*",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
